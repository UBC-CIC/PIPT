# AWS Region — ca-central-1 for GenRx (used for KVS and other AWS services)
AWS_REGION=ca-central-1

# Bedrock region — Nova Sonic is only available in us-east-1
BEDROCK_REGION=us-east-1

# KVS signaling channel name
KVS_CHANNEL_NAME=voice-agent-minimal

# NOTE: Credentials are NOT set here.
# - Local dev: run `aws sso login --profile <your-profile>` — boto3 picks up SSO creds automatically
# - Deployed (ECS): credentials come from the IAM Task Role, injected by ECS
